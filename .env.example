# Helios v6 Environment Variables
# ============================================================================
# Copy to ~/.hermes/.env and fill in your values.
# NEVER commit this file with real values.
# ============================================================================

# ─── LLM Bridge ──────────────────────────────────────────────────────────────
HELIOS_LLM_KEY=               # API key for your LLM provider
HELIOS_LLM_BASE_URL=          # e.g. http://localhost:11434/v1

# ─── Matrix Integration ────────────────────────────────────────────────────
MATRIX_HOMESERVER=             # e.g. https://matrix.example.org
MATRIX_ACCESS_TOKEN=           # Bot access token
MATRIX_ROOM=                   # e.g. !roomid:example.org
MATRIX_USER_ID=                # e.g. @helios-bot:example.org
MATRIX_DM_USER=                # e.g. @user:example.org

# ─── Home Assistant ──────────────────────────────────────────────────────────
HASS_TOKEN=                    # Long-lived access token
HOME_ASSISTANT_URL=            # e.g. http://homeassistant.local:8123
HASS_URL=                      # Alias for HOME_ASSISTANT_URL
HA_HEALTH_PREFIX=              # e.g. hae.healthsync_

# ─── iCloud ─────────────────────────────────────────────────────────────────
ICLOUD_APPLE_ID=               # Your Apple ID email (required for calendar/reminders/contacts)

# ─── Spotify ─────────────────────────────────────────────────────────────────
SPOTIPY_CLIENT_ID=             # Spotify API client ID
SPOTIPY_CLIENT_SECRET=         # Spotify API client secret
SPOTIPY_REDIRECT_URI=         # e.g. http://localhost:8888

# ─── Location ─────────────────────────────────────────────────────────────────
ICLOUD_DEVICE_TRACKER=         # e.g. device_tracker.user_iphone
HELIOS_CONTACT_EMAIL=          # Contact email for User-Agent header

# ─── Server Health (SSH) ─────────────────────────────────────────────────────
HELIOS_SSH_KEY=                # Path to SSH private key (key-based auth only)
HELIOS_SSH_USER=               # SSH username (defaults to $USER)
HELIOS_SERVERS=                # JSON file path with server definitions

# ─── Paths ────────────────────────────────────────────────────────────────────
HELIOS_HOME=                   # Override data directory (default: ~/.hermes/helios)
HELIOS_BASE=                   # Override base path (default: ~/.hermes/helios-v6/helios)